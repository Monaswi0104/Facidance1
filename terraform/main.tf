###############################################################
#  main.tf — Facidance VPS Infrastructure
#  Region : ap-south-1 (Mumbai)
#  Instance: c7i-flex.large | Ubuntu 22.04 LTS | 40 GB GP3
###############################################################

terraform {
  required_version = ">= 1.6"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
    local = {
      source  = "hashicorp/local"
      version = "~> 2.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

###############################################################
# DATA — Latest Ubuntu 22.04 LTS AMI (Canonical official)
###############################################################
data "aws_ami" "ubuntu_22_04" {
  most_recent = true
  owners      = ["099720109477"] # Canonical

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }

  filter {
    name   = "architecture"
    values = ["x86_64"]
  }
}

###############################################################
# VPC
###############################################################
resource "aws_vpc" "facidance" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = { Name = "facidance-vpc" }
}

resource "aws_internet_gateway" "facidance" {
  vpc_id = aws_vpc.facidance.id
  tags   = { Name = "facidance-igw" }
}

resource "aws_subnet" "public" {
  vpc_id                  = aws_vpc.facidance.id
  cidr_block              = "10.0.1.0/24"
  availability_zone       = "${var.aws_region}a"
  map_public_ip_on_launch = true

  tags = { Name = "facidance-public-subnet" }
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.facidance.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.facidance.id
  }

  route {
    ipv6_cidr_block = "::/0"
    gateway_id      = aws_internet_gateway.facidance.id
  }

  tags = { Name = "facidance-public-rt" }
}

resource "aws_route_table_association" "public" {
  subnet_id      = aws_subnet.public.id
  route_table_id = aws_route_table.public.id
}

###############################################################
# SECURITY GROUP
###############################################################
resource "aws_security_group" "facidance" {
  name        = "facidance-sg"
  description = "Facidance VPS security group"
  vpc_id      = aws_vpc.facidance.id

  # ── HTTP ──────────────────────────────────────────────────
  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  # ── HTTPS ─────────────────────────────────────────────────
  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  # ── SSH — your personal IPv4 ──────────────────────────────
  ingress {
    description = "SSH from owner IPv4"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["${var.owner_ipv4}/32"]
  }

  # ── SSH — your personal IPv6 ──────────────────────────────
  ingress {
    description      = "SSH from owner IPv6"
    from_port        = 22
    to_port          = 22
    protocol         = "tcp"
    ipv6_cidr_blocks = ["${var.owner_ipv6}/128"]
  }

  # NOTE: GitHub Actions SSH rule is added/removed dynamically
  # by the IAM user below — no permanent rule needed here.

  # ── Egress — all out ──────────────────────────────────────
  egress {
    from_port        = 0
    to_port          = 0
    protocol         = "-1"
    cidr_blocks      = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }

  tags = { Name = "facidance-sg" }
}

###############################################################
# KEY PAIR — generated by Terraform, private key saved locally
###############################################################
resource "tls_private_key" "facidance" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "facidance" {
  key_name   = "facidance-keypair"
  public_key = tls_private_key.facidance.public_key_openssh
  tags       = { Name = "facidance-keypair" }
}

# Saves the .pem to your local machine after apply
resource "local_sensitive_file" "private_key_pem" {
  content         = tls_private_key.facidance.private_key_pem
  filename        = "${path.module}/facidance-keypair.pem"
  file_permission = "0600"
}

###############################################################
# EC2 INSTANCE
###############################################################
resource "aws_instance" "facidance" {
  ami                    = data.aws_ami.ubuntu_22_04.id
  instance_type          = "c7i-flex.large"
  key_name               = aws_key_pair.facidance.key_name
  subnet_id              = aws_subnet.public.id
  vpc_security_group_ids = [aws_security_group.facidance.id]

  # 40 GB GP3 root volume
  root_block_device {
    volume_type           = "gp3"
    volume_size           = 40
    delete_on_termination = true
    encrypted             = true
    tags                  = { Name = "facidance-root-vol" }
  }

  # Bootstrap: install Docker + Docker Compose on first boot
  user_data = <<-EOF
    #!/bin/bash
    set -e
    apt-get update -y
    apt-get install -y ca-certificates curl gnupg lsb-release git

    # Docker
    install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
      | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
      https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
      > /etc/apt/sources.list.d/docker.list
    apt-get update -y
    apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
    systemctl enable docker
    systemctl start docker

    # Allow ubuntu user to run docker without sudo
    usermod -aG docker ubuntu

    # Create app directory
    mkdir -p /opt/facidance
    chown ubuntu:ubuntu /opt/facidance
  EOF

  tags = {
    Name        = "facidance-vps"
    Environment = "production"
  }
}

###############################################################
# ELASTIC IP — stable IP across reboots
###############################################################
resource "aws_eip" "facidance" {
  instance = aws_instance.facidance.id
  domain   = "vpc"
  tags     = { Name = "facidance-eip" }

  depends_on = [aws_internet_gateway.facidance]
}

###############################################################
# IAM — GitHub Actions user (only can manage SG rules)
###############################################################
resource "aws_iam_user" "github_actions" {
  name = "facidance-github-actions"
  tags = { Name = "facidance-github-actions" }
}

resource "aws_iam_policy" "github_actions_sg" {
  name        = "facidance-github-actions-sg-policy"
  description = "Allows GitHub Actions to open/close SSH port on the facidance SG only"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "ManageSGIngressOnly"
        Effect = "Allow"
        Action = [
          "ec2:AuthorizeSecurityGroupIngress",
          "ec2:RevokeSecurityGroupIngress"
        ]
        Resource = "arn:aws:ec2:${var.aws_region}:${var.aws_account_id}:security-group/${aws_security_group.facidance.id}"
      },
      {
        # DescribeSecurityGroups is not resource-scoped in AWS — must be *
        Sid      = "DescribeSGRead"
        Effect   = "Allow"
        Action   = ["ec2:DescribeSecurityGroups"]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_user_policy_attachment" "github_actions" {
  user       = aws_iam_user.github_actions.name
  policy_arn = aws_iam_policy.github_actions_sg.arn
}

resource "aws_iam_access_key" "github_actions" {
  user = aws_iam_user.github_actions.name
}
